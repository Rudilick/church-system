# 로컬 개발 시: 이 변수 없으면 자동으로 Vite proxy (/api → localhost:4000) 사용
# 프로덕션 배포 시 Vercel 환경변수에 아래 값 등록
VITE_API_URL=https://church-api.rudilick.com

# ── Google OAuth (필수) ───────────────────────────────────────
# Google Cloud Console > OAuth 2.0 클라이언트 ID 복사 (백엔드와 동일값)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
